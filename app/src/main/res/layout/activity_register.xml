<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout for RegisterActivity.
    Used for creating new user accounts. Includes validation and logo branding.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Global Background -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/background"
        android:scaleType="centerCrop"/>

    <!-- Theme-sensitive overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/appOverlayColor"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <!-- Logo and App Name -->
        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/equili_logo"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Equili"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"/>

        <!-- Screen Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Create Account"
            android:textSize="24sp"
            android:textColor="?attr/colorPrimary"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"/>

        <!-- Input: Email address -->
        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Email (Username)"
            android:inputType="textEmailAddress"
            android:textColor="?attr/appTextColorPrimary"
            android:textColorHint="?attr/appTextColorSecondary"
            android:padding="12dp"
            android:background="@drawable/glass_card"/>

        <!-- Input: Password with hidden characters -->
        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Password"
            android:inputType="textPassword"
            android:textColor="?attr/appTextColorPrimary"
            android:textColorHint="?attr/appTextColorSecondary"
            android:padding="12dp"
            android:background="@drawable/glass_card"/>

        <!-- Action: Submit Registration -->
        <Button
            android:id="@+id/btnRegister"
            android:text="Register"
            android:layout_marginTop="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="?attr/colorPrimary"
            android:textColor="@color/black"
            android:textSize="18sp"/>

    </LinearLayout>
</FrameLayout>
