<?xml version="1.0" encoding="utf-8"?>
<!--
    dialog_badge_unlock.xml
    Displayed when the user unlocks a new achievement badge.
    Glassmorphism card with slide-in badge icon animation.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="28dp"
    android:background="@drawable/glass_card">

    <!-- Confetti row -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎊  🎉  🏆  🎉  🎊"
        android:textSize="18sp"
        android:layout_marginBottom="10dp"/>

    <!-- "Achievement Unlocked!" label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Achievement Unlocked!"
        android:textStyle="bold"
        android:textSize="20sp"
        android:textColor="#FFD700"/>

    <!-- Animated badge icon (slide-in from bottom) -->
    <ImageView
        android:id="@+id/ivBadgeIcon"
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:src="@drawable/ic_badge_first_expense"
        android:contentDescription="Badge Icon"
        android:layout_marginVertical="16dp"/>

    <!-- Badge name -->
    <TextView
        android:id="@+id/tvBadgeName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="First Expense Logged"
        android:textStyle="bold"
        android:textSize="17sp"
        android:textColor="#FFFFFF"/>

    <!-- Divider -->
    <View
        android:layout_width="120dp"
        android:layout_height="1dp"
        android:background="#44FFFFFF"
        android:layout_marginVertical="10dp"/>

    <!-- Badge description -->
    <TextView
        android:id="@+id/tvBadgeDesc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="You logged your very first expense!"
        android:textSize="13sp"
        android:textColor="#AAAAAA"
        android:gravity="center"
        android:lineSpacingExtra="3dp"/>

</LinearLayout>
