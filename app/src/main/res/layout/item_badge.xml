<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:layout_margin="4dp"
    android:background="@drawable/glass_card"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/ivBadgeIcon"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/ic_badge_first_expense" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="16dp">

        <TextView
            android:id="@+id/tvBadgeName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Badge Name"
            android:textColor="?attr/colorPrimary"
            android:textStyle="bold"
            android:textSize="16sp"/>

        <TextView
            android:id="@+id/tvBadgeDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Badge Description"
            android:textColor="?attr/appTextColorSecondary"
            android:textSize="12sp"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <ImageView
        android:id="@+id/ivBadgeStatus"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@android:drawable/checkbox_on_background"
        app:tint="?attr/colorPrimary"/>

</LinearLayout>
