<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout for LoginActivity.
    Allows existing users to sign in using their email (username) and password.
    Supports Biometric Authentication for quick access.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Global App Background Image -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/background"
        android:scaleType="centerCrop"
        android:contentDescription="@null"/>

    <!-- Dynamic Dark Overlay (Changes based on theme) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/appOverlayColor"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Toolbar: Back button to return to the landing screen -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            app:tint="?attr/appTextColorPrimary"
            android:contentDescription="Back to Main" />

        <!-- Spacer to push content towards the center -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Brand Identity: Logo and Application Title -->
        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginBottom="16dp"
            android:src="@drawable/equili_logo"
            android:contentDescription="Equili Logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Equili"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"/>

        <!-- Input Section: Email/Username field -->
        <EditText
            android:id="@+id/etUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Username"
            android:textColor="?attr/appTextColorPrimary"
            android:textColorHint="?attr/appTextColorSecondary"
            android:layout_marginTop="32dp"
            android:padding="12dp"
            android:background="@drawable/glass_card"
            android:importantForAutofill="no"
            android:inputType="textEmailAddress"/>

        <!-- Input Section: Password field with masking -->
        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Password"
            android:inputType="textPassword"
            android:textColor="?attr/appTextColorPrimary"
            android:textColorHint="?attr/appTextColorSecondary"
            android:padding="12dp"
            android:background="@drawable/glass_card"
            android:importantForAutofill="no"/>

        <!-- Toggle for password visibility -->
        <CheckBox
            android:id="@+id/cbShowPassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:layout_marginTop="8dp"
            android:text="Show Password"
            android:textColor="?attr/appTextColorPrimary"
            android:buttonTint="?attr/colorPrimary" />

        <!-- Main Action: Standard Password Login -->
        <Button
            android:id="@+id/btnLogin"
            android:text="Login"
            android:layout_marginTop="32dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="?attr/colorPrimary"
            android:textColor="@color/black"/>

        <!-- Quick Access: Biometric (Fingerprint/Face) Login Button -->
        <ImageButton
            android:id="@+id/btnBiometric"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginTop="16dp"
            android:src="@android:drawable/ic_lock_idle_lock"
            android:background="@drawable/glass_card"
            app:tint="?attr/colorPrimary"
            android:visibility="gone"
            android:contentDescription="Fingerprint Login" />

        <!-- Recovery: Forgot Password link -->
        <TextView
            android:id="@+id/tvForgotPassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Forgot Password?"
            android:textColor="?attr/colorPrimary"
            android:textSize="14sp"
            android:clickable="true"
            android:focusable="true" />

        <!-- Bottom spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

</FrameLayout>
