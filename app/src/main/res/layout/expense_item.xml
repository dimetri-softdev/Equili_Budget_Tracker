<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout for a single expense entry in the RecyclerView.
    Uses a 'glass_card' background for a modern fintech look.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
    android:padding="12dp"
    android:layout_margin="4dp"
    android:background="@drawable/glass_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical">

    <!-- Category Icon -->
    <ImageView
        android:id="@+id/ivCategoryIcon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="12dp"
        android:src="@drawable/ic_categories"
        app:tint="?attr/colorPrimary" />

    <!-- Thumbnail of the receipt photo, hidden by default if no photo exists -->
    <ImageView
        android:id="@+id/ivSmallPhoto"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:scaleType="centerCrop"
        android:layout_marginEnd="12dp"
        android:visibility="gone"
        android:background="#20FFFFFF"/>

    <!-- Expense details: Title, Category/Times, and Date -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_weight="1">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="?attr/appTextColorPrimary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="?attr/appTextColorSecondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#888"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Expense amount, highlighted with the primary brand color -->
    <TextView
        android:id="@+id/tvAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="?attr/colorPrimary"
        android:textSize="20sp"
        android:textStyle="bold" />

</LinearLayout>
