<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/glass_card"
    android:gravity="center_horizontal">

    <ImageView
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@android:drawable/ic_menu_help"
        app:tint="?attr/colorPrimary"
        android:layout_marginBottom="12dp"
        android:contentDescription="AI Advisor" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Equili AI Advisor"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="?attr/colorPrimary"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvAiResponse"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Analyzing your financial habits..."
        android:textColor="?attr/appTextColorPrimary"
        android:textSize="14sp"
        android:lineSpacingExtra="4dp"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <ProgressBar
        android:id="@+id/pbAiLoading"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        android:visibility="gone"
        android:layout_marginBottom="16dp"/>

</LinearLayout>
